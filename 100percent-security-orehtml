  <style>
    :root {
      --gold: #C9A84C;
      --gold-light: #E8C870;
      --dark: #0A0A0A;
      --dark2: #111111;
      --dark3: #1A1A1A;
      --white: #F5F5F0;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { background: var(--dark); color: var(--white); font-family: 'Barlow', sans-serif; overflow-x: hidden; }

    /* TOP BAR */
    .topbar {
      background: var(--gold);
      padding: 0.4rem 4rem;
      display: flex; justify-content: space-between; align-items: center;
      font-size: 0.75rem; font-weight: 600; color: var(--dark); letter-spacing: 0.05em;
    }
    .topbar a { color: var(--dark); text-decoration: none; }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 4rem;
      background: rgba(10,10,10,0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(201,168,76,0.2);
    }
    .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 0.1em; color: var(--gold); line-height: 1.1; }
    .nav-logo span { color: var(--white); display: block; font-size: 0.85rem; }
    .nav-links { display: flex; gap: 0; list-style: none; }
    .nav-links > li { position: relative; }
    .nav-links > li > a { color: rgba(245,245,240,0.75); text-decoration: none; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; padding: 0.6rem 1.1rem; display: block; transition: color 0.2s; }
    .nav-links > li > a:hover { color: var(--gold); }
    .nav-links > li:hover .dropdown { display: block; }
    .dropdown { display: none; position: absolute; top: 100%; left: 0; background: var(--dark2); border: 1px solid rgba(201,168,76,0.15); min-width: 220px; z-index: 200; }
    .dropdown a { display: block; padding: 0.7rem 1.2rem; font-size: 0.78rem; color: rgba(245,245,240,0.65); text-decoration: none; letter-spacing: 0.08em; border-bottom: 1px solid rgba(255,255,255,0.04); transition: all 0.2s; }
    .dropdown a:hover { color: var(--gold); background: rgba(201,168,76,0.05); padding-left: 1.5rem; }
    .nav-cta { background: var(--gold) !important; color: var(--dark) !important; padding: 0.6rem 1.4rem !important; font-weight: 700 !important; }
    .nav-cta:hover { background: var(--gold-light) !important; color: var(--dark) !important; }

    /* HERO */
    .hero { min-height: 92vh; display: flex; align-items: center; position: relative; padding: 6rem 4rem 4rem; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 70% 50%, rgba(201,168,76,0.07) 0%, transparent 70%), linear-gradient(135deg, #080808 0%, #131313 100%); }
    .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(201,168,76,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(201,168,76,0.035) 1px, transparent 1px); background-size: 60px 60px; }
    .hero-content { position: relative; z-index: 2; max-width: 750px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 0.6rem; background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.3); padding: 0.4rem 1rem; border-radius: 2px; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 2rem; animation: fadeUp 0.8s ease both; }
    .badge-dot { width: 6px; height: 6px; background: var(--gold); border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }
    .hero h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3.2rem, 8vw, 7.5rem); line-height: 0.93; letter-spacing: 0.02em; color: var(--white); animation: fadeUp 0.8s ease 0.1s both; }
    .hero h1 .gold { color: var(--gold); }
    .hero-sub { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(1rem, 2vw, 1.5rem); letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,245,240,0.45); margin: 1.2rem 0 2rem; animation: fadeUp 0.8s ease 0.2s both; }
    .hero-desc { font-size: 1rem; line-height: 1.75; color: rgba(245,245,240,0.6); max-width: 500px; margin-bottom: 2.5rem; font-weight: 300; animation: fadeUp 0.8s ease 0.3s both; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.8s ease 0.4s both; }
    .btn-primary { background: var(--gold); color: var(--dark); padding: 0.9rem 2.2rem; font-family: 'Barlow Condensed', sans-serif; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; border-radius: 2px; transition: all 0.2s; display: inline-block; border: none; cursor: pointer; }
    .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,168,76,0.3); }
    .btn-outline { border: 1px solid rgba(245,245,240,0.3); color: var(--white); padding: 0.9rem 2.2rem; font-family: 'Barlow Condensed', sans-serif; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; border-radius: 2px; transition: all 0.2s; display: inline-block; }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
    .hero-stats { position: absolute; right: 4rem; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 2rem; animation: fadeIn 1s ease 0.5s both; }
    .hero-stat { text-align: right; }
    .hero-stat .num { font-family: 'Bebas Neue', sans-serif; font-size: 2.8rem; color: var(--gold); line-height: 1; }
    .hero-stat .label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,245,240,0.35); }
    .hero-vline { position: absolute; right: 3.6rem; top: 50%; transform: translateY(-50%); width: 1px; height: 45%; background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.35), transparent); }
    @keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }

    /* HOTLINE STRIP */
    .hotline-strip { background: var(--dark2); border-top: 3px solid var(--gold); border-bottom: 1px solid rgba(201,168,76,0.1); padding: 2rem 4rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; }
    .hotline-left { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,245,240,0.5); }
    .hotline-num { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; color: var(--gold); letter-spacing: 0.05em; }
    .hotline-tag { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,245,240,0.35); }

    /* SECTION HELPERS */
    .section-label { font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.8rem; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.2rem, 4vw, 4rem); line-height: 1; margin-bottom: 1rem; }
    .section-desc { color: rgba(245,245,240,0.5); font-weight: 300; font-size: 0.95rem; line-height: 1.75; max-width: 520px; margin-bottom: 2.5rem; }

    /* BACKGROUND */
    .welcome { padding: 7rem 4rem; background: var(--dark); display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
    .welcome-visual { background: var(--dark3); border: 1px solid rgba(201,168,76,0.15); padding: 3.5rem; position: relative; }
    .welcome-visual::after { content:''; position:absolute; bottom:-12px; right:-12px; width:100%; height:100%; border:1px solid rgba(201,168,76,0.06); z-index:-1; }
    .welcome-big { font-family: 'Bebas Neue', sans-serif; font-size: 6rem; color: var(--gold); line-height: 1; }
    .welcome-sub-label { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,245,240,0.35); margin-bottom: 2rem; }
    .welcome-points { list-style: none; display: flex; flex-direction: column; gap: 0.9rem; }
    .welcome-points li { display: flex; align-items: flex-start; gap: 0.8rem; font-size: 0.88rem; color: rgba(245,245,240,0.6); font-weight: 300; }
    .welcome-points li::before { content:'▸'; color:var(--gold); flex-shrink:0; }

    /* SERVICES */
    .services { padding: 7rem 4rem; background: var(--dark2); }
    .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1px; background: rgba(201,168,76,0.06); border: 1px solid rgba(201,168,76,0.06); margin-top: 1rem; }
    .service-card { background: var(--dark2); padding: 0; transition: background 0.3s; position: relative; overflow: hidden; }
    .service-card::before { content:''; position:absolute; top:0; left:0; width:3px; height:0; background:var(--gold); transition:height .4s ease; z-index:2; }
    .service-card:hover::before { height:100%; }
    .service-card:hover { background: var(--dark3); }
    .service-img { width:100%; height:180px; object-fit:cover; display:block; filter: brightness(0.75); transition: filter 0.3s; }
    .service-card:hover .service-img { filter: brightness(0.9); }
    .service-card-body { padding: 1.8rem 2rem; }
    .service-icon { font-size: 2rem; margin-bottom: 1.2rem; }
    .service-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.7rem; }
    .service-card p { font-size: 0.86rem; line-height: 1.7; color: rgba(245,245,240,0.5); font-weight: 300; }

    /* MVV */
    .mvv { padding: 7rem 4rem; background: var(--dark3); }
    .mvv-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2rem; margin-top: 3rem; }
    .mvv-card { background: var(--dark2); border: 1px solid rgba(201,168,76,0.12); padding: 2.5rem; position: relative; transition: border-color 0.3s; }
    .mvv-card:hover { border-color: rgba(201,168,76,0.4); }
    .mvv-number { font-family: 'Bebas Neue', sans-serif; font-size: 5rem; color: rgba(201,168,76,0.07); position: absolute; top: 1rem; right: 1.5rem; line-height: 1; }
    .mvv-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    .mvv-card p { font-size: 0.88rem; line-height: 1.75; color: rgba(245,245,240,0.55); font-weight: 300; }

    /* CORE VALUES */
    .core-values { padding: 7rem 4rem; background: var(--dark); }
    .values-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 1.5rem; margin-top: 3rem; }
    .value-item { border: 1px solid rgba(201,168,76,0.12); padding: 2rem 1.5rem; text-align: center; transition: all 0.3s; }
    .value-item:hover { border-color: var(--gold); background: rgba(201,168,76,0.04); }
    .value-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
    .value-item h4 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.6rem; }
    .value-item p { font-size: 0.82rem; line-height: 1.6; color: rgba(245,245,240,0.45); font-weight: 300; }

    /* COVERAGE */
    .coverage { padding: 5rem 4rem; background: var(--gold); text-align: center; }
    .coverage h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); color: var(--dark); letter-spacing: 0.04em; }
    .coverage p { color: rgba(10,10,10,0.6); font-size: 0.95rem; margin: 1rem auto 2rem; max-width: 500px; }
    .states-list { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; max-width: 700px; margin: 0 auto; }
    .state-tag { background: rgba(10,10,10,0.12); color: var(--dark); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 2px; }

    /* OBJECTIVES */
    .objectives { padding: 7rem 4rem; background: var(--dark2); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .obj-list { list-style: none; display: flex; flex-direction: column; gap: 1.2rem; margin-top: 2rem; counter-reset: obj; }
    .obj-list li { display: flex; align-items: flex-start; gap: 1.2rem; font-size: 0.9rem; color: rgba(245,245,240,0.65); font-weight: 300; line-height: 1.6; counter-increment: obj; }
    .obj-list li::before { content: counter(obj, decimal-leading-zero); font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; color: var(--gold); flex-shrink: 0; line-height: 1.1; }

    /* QUALITY */
    .quality { padding: 5rem 4rem; background: var(--dark3); }
    .quality-inner { max-width: 800px; }
    .quality blockquote { font-size: 1.15rem; line-height: 1.85; color: rgba(245,245,240,0.7); font-weight: 300; border-left: 3px solid var(--gold); padding-left: 2rem; margin-top: 2rem; font-style: italic; }

    /* AFFILIATIONS */
    .affiliations { padding: 4rem 4rem; background: var(--dark2); text-align: center; }
    .affiliations h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 0.08em; color: rgba(245,245,240,0.3); margin-bottom: 2rem; }
    .aff-list { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
    .aff-badge { border: 1px solid rgba(201,168,76,0.2); padding: 0.7rem 1.5rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,245,240,0.5); }

    /* LEADERSHIP */
    .leadership { padding: 7rem 4rem; background: var(--dark); }
    .team-grid { display: flex; gap: 2.5rem; flex-wrap: wrap; margin-top: 3rem; }
    .team-card { background: var(--dark3); border: 1px solid rgba(201,168,76,0.12); padding: 2.5rem; max-width: 300px; width: 100%; transition: border-color 0.3s; }
    .team-card:hover { border-color: rgba(201,168,76,0.4); }
    .team-avatar { width: 72px; height: 72px; background: var(--gold); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin-bottom: 1.5rem; }
    .team-role { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
    .team-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.04em; margin-bottom: 0.8rem; }
    .team-desc { font-size: 0.85rem; line-height: 1.7; color: rgba(245,245,240,0.45); font-weight: 300; }

    /* CONTACT */
    .contact { padding: 7rem 4rem; background: var(--dark2); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .contact-detail { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 2rem; }
